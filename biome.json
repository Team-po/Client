{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!dist", "!node_modules"]
	},
	"formatter": {
		"enabled": true
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noUnknownAtRules": "off"
			}
		}
	}
}
